# Copy this file to .env and fill your own values.
# The refresh script auto-loads ./.env by default.

# Recommended for SEC API reliability.
# Example: SEC_USER_AGENT="Ju Woocheol juuc@example.com"
SEC_USER_AGENT=""

# Required for Korea disclosure holdings (OpenDART).
OPENDART_API_KEY=""

# Optional: enables KRW value-based Korea weights via KIS quotes.
KIS_APP_KEY=""
KIS_APP_SECRET=""
